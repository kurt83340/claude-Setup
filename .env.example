# ============================================================
# ACME Sync ERP→Notion — variables d'environnement
# Copier ce fichier en .env et remplir avec les vraies valeurs
# (demander les valeurs à Marie ACME — voir docs/ACCESS.md)
# ============================================================

# SAP Business One Service Layer
SAP_B1_BASE_URL=https://erp.acme.local:50000/b1s/v1
SAP_B1_COMPANY_DB=ACME_PROD
SAP_B1_USERNAME=
SAP_B1_PASSWORD=

# Notion API
NOTION_API_KEY=
NOTION_DB_COMMANDES_ID=

# n8n (pour déploiement via /push-n8n)
N8N_BASE_URL=https://n8n.acme.local
N8N_API_KEY=

# Observabilité
SENTRY_DSN=
LOG_LEVEL=INFO

# Misc
ENVIRONMENT=local  # local | staging | prod
