# ============================================================
# {{PROJECT_NAME}} — variables d'environnement
# Copier en .env et remplir (valeurs : voir .claude/docs/ACCESS.md).
# ⚠️ Ne JAMAIS committer .env (déjà gitignored). Aucun secret ici.
# Décommente/renomme les blocs selon ta stack ; supprime le reste.
# ============================================================

# --- Service tiers principal (API métier / ERP / SaaS) ---
# {{SERVICE}}_BASE_URL=
# {{SERVICE}}_API_KEY=

# --- Base de données (si applicable) ---
# DATABASE_URL=

# --- n8n (si type automation-n8n) ---
# N8N_BASE_URL=
# N8N_API_KEY=

# --- Observabilité (optionnel) ---
# SENTRY_DSN=
LOG_LEVEL=INFO

# --- Divers ---
ENVIRONMENT=local  # local | staging | prod
